{
  "private": true,
  "name": "remnote-mcp-bridge",
  "version": "0.13.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "check-types": "tsc",
    "dev": "cross-env NODE_ENV=development webpack-dev-server --color --progress --no-open",
    "build": "npx remnote-plugin validate && shx rm -rf dist && cross-env NODE_ENV=production webpack --color --progress && cd dist && bestzip ../PluginZip.zip ./*",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "lint:fix": "npx eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" --fix",
    "format": "npx prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "quality": "./code-quality.sh",
    "precommit": "./code-quality.sh"
  },
  "dependencies": {
    "@remnote/plugin-sdk": "0.0.46",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^17.0.91",
    "@types/react-dom": "^17.0.26",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.3",
    "autoprefixer": "^10.5.0",
    "bestzip": "^2.2.3",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "esbuild-loader": "^4.4.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "react-refresh": "^0.18.0",
    "shx": "^0.4.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
